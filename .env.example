# Copy to .env and fill in. Used by docker-compose at runtime.

# --- Phase 7: Google Sign-In ---
# Required to enable the sign-in flow. Get this from Google Cloud Console:
#   APIs & Services → Credentials → OAuth 2.0 Client IDs → Web application.
# Add http://localhost:8080 and your production origin to authorized JS origins.
GOOGLE_CLIENT_ID=

# Comma-separated list of Google account emails granted admin rights.
# Admins can: delete any player, hit DELETE /api/admin/reset.
ADMIN_EMAILS=
