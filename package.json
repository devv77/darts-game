{
  "name": "darts-game",
  "version": "2.0.0",
  "description": "Self-hosted darts counter — Fastify + React monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=@darts/server",
    "dev:web": "npm run dev --workspace=@darts/web",
    "dev": "npm-run-all -p dev:server dev:web",
    "build:server": "npm run build --workspace=@darts/server",
    "build:web": "npm run build --workspace=@darts/web",
    "build": "npm run test && npm run build:server && npm run build:web",
    "start": "node apps/server/dist/index.js",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  }
}
