# Copy to .env and fill in. Used by `docker compose up` at runtime.
# Production .env lives at /opt/apps/darts-game/.env on the deploy host.

# --- Google Sign-In (Phase 7) ---
# Frontend uses Google Identity Services (ID-token flow); the server only
# needs the CLIENT_ID. Get it from Google Cloud Console:
#   APIs & Services → Credentials → OAuth 2.0 Client IDs → Web application.
# Add the URL you load the app from to the Authorized JS origins:
#   http://localhost:8080 for `docker compose up`
#   http://localhost:5173 for `npm run dev`
GOOGLE_CLIENT_ID=

# Comma-separated Google account emails granted admin in the app.
# Admins can edit any player and hit DELETE /api/admin/reset.
ADMIN_EMAILS=

# --- CORS allow-list ---
# Optional. Defaults to http://localhost:8080 (docker-compose.yml).
# In production, set to the public FQDN, e.g. https://darts.csodakucko.net.
# ALLOWED_ORIGINS=
